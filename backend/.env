NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/stocktrading

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# JWT (local dev - change for production)
JWT_SECRET=dev_jwt_secret_change_me_9f3b2c
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_a7d1e4
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stock API (Alpha Vantage - free tier)
ALPHA_VANTAGE_API_KEY=
# POLYGON_API_KEY left empty for local dev
POLYGON_API_KEY=

# Email (Nodemailer) - optional for local dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Initial wallet balance for new users
DEFAULT_WALLET_BALANCE=100000
