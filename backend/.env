NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/stocktrading

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# JWT (local dev - change for production)
JWT_SECRET=replace_with_a_local_jwt_secret
JWT_REFRESH_SECRET=replace_with_a_local_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Financial Data APIs ────────────────────────────────────────────────────────

# FMP — Real-time batch quotes, company profiles (250 calls/day free)
FMP_API_KEY=replace_with_fmp_api_key

# Alpha Vantage — Historical OHLC candlestick data (25 calls/day free)
ALPHA_VANTAGE_API_KEY=replace_with_alpha_vantage_api_key

# ─── News APIs ─────────────────────────────────────────────────────────────────

# Finnhub — Market news + stock-specific news (60 calls/min free)
FINNHUB_API_KEY=replace_with_finnhub_api_key

# Marketaux — Financial news with sentiment scores (100 requests/day free)
MARKETAUX_API_KEY=replace_with_marketaux_api_key

# NewsData.io — Broad business/financial news (200 requests/day free)
NEWSDATA_API_KEY=replace_with_newsdata_api_key

# ─── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

# GitHub OAuth2 (optional — leave blank to use sandbox mode)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (Nodemailer) - optional for local dev
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=replace_with_smtp_user
SMTP_PASS=replace_with_smtp_password

# Frontend URL (for CORS and OAuth redirect)
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Initial wallet balance for new users
DEFAULT_WALLET_BALANCE=100000
